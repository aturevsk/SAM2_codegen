# Binary weight files (too large for GitHub — extract locally with reference/extract_weights.py)
weights/
*.bin
*.pt2
*.onnx

# MATLAB build artifacts — logs and temp
matlab_coder/codegen/
matlab_coder/codegen_error.mat
matlab_coder/codegen_summary.mat
matlab_coder/*.mex*
matlab_coder/*_bg.log
matlab_coder/benchmark_status.txt
matlab_coder/codegen_status.txt
matlab_coder/timing_status.txt
matlab_coder/verify_results.mat
matlab_coder/cpp_bench_results.txt
# outDir tracked (generated C++ sources), but skip .bin weight files and .o/.a build artifacts
matlab_coder/outDir/*.bin
matlab_coder/outDir/*.o
matlab_coder/outDir/*.a
matlab_coder/outDir/*.mex*

# C++ build artifacts
manual_cpp/build/

# Python cache
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Reference I/O test vectors (large, regenerate with gen_reference.py)
reference/ref_input_image.bin
reference/ref_input_coords.bin
reference/ref_input_labels.bin
reference/ref_output_0.bin
reference/ref_output_1.bin
reference/manual_cpp_output_*.bin
